// Ejemplo 3: VARIANTE 1 - while (iteración con condición al inicio)
program bucle_while {

    // Conteo simple
    var i : int = 0;
    while (i < 5) {
        print(i);
        i = i + 1;
    }

    // Suma de 1 a 10
    var n     : int = 10;
    var suma  : int = 0;
    var k     : int = 1;
    while (k <= n) {
        suma = suma + k;
        k = k + 1;
    }
    print("Suma 1..10:");
    print(suma);          // 55

    // El cuerpo puede no ejecutarse nunca si la condición es falsa de entrada
    var x : int = 100;
    while (x < 0) {
        print("no se imprime");
        x = x + 1;
    }
    print("Listo");
}
